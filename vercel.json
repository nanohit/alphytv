{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/curated-live.json",
      "destination": "https://nvpuetq65dds3gtx.public.blob.vercel-storage.com/catalog/curated.json"
    },
    {
      "source": "/:id(\\d+)",
      "destination": "/"
    },
    {
      "source": "/k/:id(\\d+)",
      "destination": "/"
    },
    {
      "source": "/m/:id(\\d+)",
      "destination": "/"
    },
    {
      "source": "/r/:path*",
      "destination": "/"
    },
    {
      "source": "/c/:path*",
      "destination": "/"
    },
    {
      "source": "/o/:path*",
      "destination": "/"
    },
    {
      "source": "/n/:path*",
      "destination": "/"
    },
    {
      "source": "/search/:path*",
      "destination": "/"
    },
    {
      "source": "/bookmarks",
      "destination": "/"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
